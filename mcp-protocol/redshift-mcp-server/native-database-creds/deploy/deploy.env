# Deployment configuration for the Redshift MCP server (CloudFormation).
# Sourced by deploy-cfn.sh. No secrets — Redshift credentials are supplied per
# request by end users in HTTP headers, never stored on the server.
#
# Copy this file and fill in your own values before deploying.

# ---- Core ----
AWS_REGION=<your-aws-region>
STACK_NAME=<your-stack-name>
S3_BUCKET=<your-s3-bucket-name>
S3_KEY=redshift-mcp.tar.gz

INSTANCE_TYPE=t4g.xlarge                        # Graviton / arm64
VPC_ID=<your-vpc-id>
# A single instance uses ONE private subnet; the second is spare (for a future 2nd instance/ASG).
EC2_SUBNET_ID=<your-private-subnet-id>          # PRIVATE subnet for the EC2 instance

# ---- Names created by the stack ----
EC2_SECURITY_GROUP_NAME=<your-stack-name>-ec2-sg
ALB_SECURITY_GROUP_NAME=<your-stack-name>-alb-sg
EC2_INSTANCE_PROFILE_NAME=<your-stack-name>-ec2-instance-profile

# ---- Public ALB (CloudFront origin; default cert handles client TLS) ----
# >=2 PUBLIC subnets in different AZs (IGW route) — REQUIRED for internet-facing ALB.
PUBLIC_SUBNET_IDS=<your-public-subnet-1>,<your-public-subnet-2>

# ---- Redshift target ----
RS_HOST=<your-redshift-cluster>.region.redshift.amazonaws.com
RS_PORT=5439
RS_DB=<your-database-name>
REDSHIFT_SG_ID=<your-redshift-security-group-id>

# ---- Logs ----
CW_LOG_GROUP=/redshift-mcp/app
